#: ui/main.qml:32
#, kde-format
msgid ""
"User Feedback has been disabled centrally. Please contact your distributor."
msgstr "משוב המשתמש הושבת מרכזית. נא ליצור קשר עם המפיץ."

#: ui/main.qml:44
#, kde-kuit-format
msgctxt "@info"
msgid ""
"You can help KDE improve Plasma by contributing information on how you use "
"it, so we can focus on things that matter to you.<nl/><nl/>Contributing this "
"information is optional and entirely anonymous. We never collect your "
"personal data, files you use, websites you visit, or information that could "
"identify you.<nl/>"
msgstr ""
"אפשר לסייע ל־KDE לשפר את פלזמה על ידי תרומת מידע על דפוס השימוש שלך כדי "
"שנוכל להתמקד על הדברים שחשובים לך.<nl/><nl/>תרומת המידע היא בהתנדבות והיא "
"אלמונית לחלוטין. אנחנו לעולם לא אוספים את הנתונים האישיים שלך, קבצים שבהם "
"השתמשת, אתרים שבהם ביקרת או מידע שיכול לחשוף אותך.<nl/>"

#: ui/main.qml:51
#, kde-format
msgctxt "@info"
msgid "Read more about our privacy policy"
msgstr "מידע נוסף על מדיניות הפרטיות שלנו"

