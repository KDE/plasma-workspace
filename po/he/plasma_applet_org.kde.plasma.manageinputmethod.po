#: qml/main.qml:70
#, kde-format
msgctxt "Opens the system settings module"
msgid "Configure Virtual Keyboards..."
msgstr "הגדרות מקלדות וירטואליות…"

#: qml/main.qml:87
#, kde-format
msgid "Virtual Keyboard: unavailable"
msgstr "מקלדת וירטואלית: לא זמינה"

#: qml/main.qml:96
#, kde-format
msgid "Virtual Keyboard: disabled"
msgstr "מקלדת וירטואלית: מושבתת"

#: qml/main.qml:108
#, kde-format
msgid "Show Virtual Keyboard"
msgstr "הצגת מקלדת וירטואלית"

#: qml/main.qml:119
#, kde-format
msgid "Virtual Keyboard: visible"
msgstr "מקלדת וירטואלית: גלויה"

#: qml/main.qml:128
#, kde-format
msgid "Virtual Keyboard: Show on non-mouse input"
msgstr "מקלדת וירטואלית: להציג עם קלט שאינו עכבר"

#: qml/main.qml:137
#, kde-format
msgid "Virtual Keyboard: Show with all input devices"
msgstr "מקלדת וירטואלית: להציג עם כל התקני הקלט"

#~ msgid "Virtual Keyboard: enabled"
#~ msgstr "מקלדת וירטואלית: פעילה"
