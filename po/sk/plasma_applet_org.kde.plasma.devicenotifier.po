#: actions/checkaction.cpp:71
#, kde-format
msgctxt "@action:button check a storageAccess (i.e disk) for error"
msgid "Check for Errors"
msgstr "Kontrola chýb"

#: actions/mountaction.cpp:93
#, kde-format
msgid "Mount"
msgstr "Pripojiť"

#: actions/mountandopenaction.cpp:173
#, kde-format
msgid "Open in File Manager"
msgstr "Otvoriť v správcovi súborov"

#: actions/mountandopenaction.cpp:176
#, kde-format
msgid "Try to Fix"
msgstr "Skúsiť opraviť"

#: actions/mountandopenaction.cpp:176
#, kde-format
msgid "Mount and Open"
msgstr "Pripojiť a otvoriť"

#: actions/mountandopenaction.cpp:178
#, kde-format
msgid "Eject"
msgstr "Vysunúť"

#: actions/mountandopenaction.cpp:180
#, kde-format
msgid "Safely remove"
msgstr "Bezpečne odstrániť"

#: messageinfo.cpp:108
#, kde-format
msgid "This device has file system errors."
msgstr "Toto zariadenie má chyby v súborovom systéme."

#: messageinfo.cpp:110
#, kde-format
msgctxt "@label device is a storage disk"
msgid "This device has no errors"
msgstr "Toto zariadenie nemá žiadne chyby."

#: messageinfo.cpp:113
#, kde-format
msgid "Successfully repaired!"
msgstr "Úspešne opravené!"

#: messageinfo.cpp:117
#, kde-format
msgid "Device Status"
msgstr "Stav zariadení"

#: messageinfo.cpp:118
#, kde-format
msgid "A device can now be safely removed"
msgstr "Zariadenie môže byť teraz bezpečne odstránené"

#: messageinfo.cpp:122
#, kde-format
msgid "This device can now be safely removed."
msgstr "Toto zariadenie môže byť teraz bezpečne odstránené."

#: messageinfo.cpp:129
#, kde-format
msgid "You are not authorized to mount this device."
msgstr "Nemáte oprávnenie na pripojenie tohto zariadenia."

#: messageinfo.cpp:133
#, kde-format
msgid "You are not authorized to eject this disc."
msgstr "Nemáte oprávnenie na vysunutie tohto disku."

#: messageinfo.cpp:136
#, kde-format
msgctxt "Remove is less technical for unmount"
msgid "You are not authorized to remove this device."
msgstr "Nemáte oprávnenie na odstránenie tohto zariadenia."

#: messageinfo.cpp:139
#, kde-format
msgid "You are not authorized to repair this device."
msgstr "Nie ste oprávnení opravovať toto zariadenie."

#: messageinfo.cpp:141 messageinfo.cpp:208
#, kde-format
msgid "Unknown error type"
msgstr "Neznámy typ chyby"

#: messageinfo.cpp:145
#, kde-format
msgid "Could not mount this device as it is busy."
msgstr "Nepodarilo sa pripojiť toto zariadenie, pretože je zaneprázdnené."

#: messageinfo.cpp:173
#, kde-format
msgid "One or more files on this device are open within an application."
msgstr ""
"Jeden alebo viac súborov na tomto zariadení sú stále otvorené v nejakej "
"aplikácii."

#: messageinfo.cpp:175
#, kde-format
msgid "One or more files on this device are opened in application \"%2\"."
msgid_plural ""
"One or more files on this device are opened in following applications: %2."
msgstr[0] ""
"Jeden alebo viac súborov na tomto zariadení sú otvorené v aplikácii \"%2\"."
msgstr[1] ""
"Jeden alebo viac súborov na tomto zariadení sú otvorené v aplikáciách: %2."
msgstr[2] ""
"Jeden alebo viac súborov na tomto zariadení sú otvorené v aplikáciách: %2."

#: messageinfo.cpp:178
#, kde-format
msgctxt "separator in list of apps blocking device unmount"
msgid ", "
msgstr ", "

#: messageinfo.cpp:197
#, kde-format
msgid "Could not mount this device."
msgstr "Toto zariadenie sa nepodarilo pripojiť."

#: messageinfo.cpp:201
#, kde-format
msgid "Could not eject this disc."
msgstr "Tento disk sa nepodarilo vysunúť."

#: messageinfo.cpp:203
#, kde-format
msgctxt "Remove is less technical for unmount"
msgid "Could not remove this device."
msgstr "Toto zariadenie sa nepodarilo odstrániť."

#: messageinfo.cpp:206
#, kde-format
msgid "Could not repair this device: %1"
msgstr "Toto zariadenie sa nepodarilo opraviť: %1"

#: qml/DeviceItem.qml:99
#, kde-format
msgctxt ""
"Translation should be short and mean 'Currently checking the device for "
"filesystem errors'"
msgid "Checking…"
msgstr "Odstraňuje sa…"

#: qml/DeviceItem.qml:101
#, kde-format
msgctxt ""
"Translation should be short and mean 'The storage device contains filesystem "
"errors and is being repaired'"
msgid "Repairing…"
msgstr "Odstraňuje sa…"

#: qml/DeviceItem.qml:104
#, kde-format
msgctxt "@info:status Free disk space"
msgid "%1 free of %2"
msgstr "%1 voľných z %2"

#: qml/DeviceItem.qml:108
#, kde-format
msgctxt ""
"Accessing is a less technical word for Mounting; translation should be short "
"and mean 'Currently mounting this device'"
msgid "Accessing…"
msgstr "Pristupuje sa…"

#: qml/DeviceItem.qml:111
#, kde-format
msgctxt ""
"Removing is a less technical word for Unmounting; translation should be "
"short and mean 'Currently unmounting this device'"
msgid "Removing…"
msgstr "Odstraňuje sa…"

#: qml/DeviceItem.qml:114
#, kde-format
msgid "Don't unplug yet! Files are still being transferred…"
msgstr "Ešte sa neodpájajte! Súbory sa stále prenášajú..."

#: qml/FullRepresentation.qml:47 qml/main.qml:123
#, kde-format
msgid "Remove All"
msgstr "Odpojiť všetky"

#: qml/FullRepresentation.qml:48
#, kde-format
msgid "Click to safely remove all devices"
msgstr "Kliknutím bezpečne odstránite všetky zariadenia"

#: qml/FullRepresentation.qml:162
#, kde-format
msgid "No removable devices attached"
msgstr "Nie sú pripojené žiadne vymeniteľné zariadenia"

#: qml/FullRepresentation.qml:162
#, kde-format
msgid "No disks available"
msgstr "Nie sú dostupné žiadne disky"

#: qml/main.qml:72
#, kde-format
msgid "Most Recent Device"
msgstr "Najnovšie zariadenie"

#: qml/main.qml:72
#, kde-format
msgid "No Devices Available"
msgstr "Žiadne dostupné zariadenia"

#: qml/main.qml:109
#, kde-format
msgctxt "Open auto mounter kcm"
msgid "Configure Removable Devices…"
msgstr "Nastaviť vymeniteľné zariadenia…"

#: qml/main.qml:131
#, kde-format
msgid "Removable Devices"
msgstr "Vymeniteľné zariadenia"

#: qml/main.qml:146
#, kde-format
msgid "Non Removable Devices"
msgstr "Nevymeniteľné zariadenia"

#: qml/main.qml:161
#, kde-format
msgid "All Devices"
msgstr "Všetky zariadenia"

#: qml/main.qml:178
#, kde-format
msgid "Show popup when new device is plugged in"
msgstr "Otvoriť vyskakovacie okno po pripojení nového zariadenia"

