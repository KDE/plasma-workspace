#: autostartmodel.cpp:381
#, kde-format
msgid "\"%1\" is not an absolute url."
msgstr "\"%1\" m̄-sī tsua̍t-tuì URL."

#: autostartmodel.cpp:384
#, kde-format
msgid "\"%1\" does not exist."
msgstr "\"%1\" bô tsûn-tsāi."

#: autostartmodel.cpp:387
#, kde-format
msgid "\"%1\" is not a file."
msgstr "\"%1\" m̄-sī tóng-àn."

#: autostartmodel.cpp:390
#, kde-format
msgid "\"%1\" is not readable."
msgstr "\"%1\" bô-huat-tōo tho̍k-tshú."

#: ui/entry.qml:30
#, kde-format
msgctxt "@label Stop the Systemd unit for a running process"
msgid "Stop"
msgstr "Thîng"

#: ui/entry.qml:31
#, kde-format
msgctxt "@label Start the Systemd unit for a currently inactive process"
msgid "Start"
msgstr "Khai-sí"

#: ui/entry.qml:71
#, kde-format
msgctxt ""
"@label The name of a Systemd unit for an app or script that will autostart"
msgid "Name:"
msgstr "Miâ:"

#: ui/entry.qml:77
#, kde-format
msgctxt ""
"@label The current status (e.g. active or inactive) of a Systemd unit for an "
"app or script that will autostart"
msgid "Status:"
msgstr "Tsōng-thài:"

#: ui/entry.qml:83
#, kde-format
msgctxt ""
"@label A date and time follows this text, making a sentence like 'Last "
"activated on: August 7th 11 PM 2023'"
msgid "Last activated on:"
msgstr "Tíng-kái activate ê sî-kan:"

#: ui/entry.qml:114
#, kde-format
msgid "Unable to load logs. Try refreshing."
msgstr "Bô-huat-tōo tsài-ji̍p kì-lo̍k. Tshiánn tshì-khuànn-māi tîng tsíng-lí."

#: ui/entry.qml:118
#, kde-format
msgctxt "@action:button Refresh entry logs when it failed to load"
msgid "Refresh"
msgstr "Tîng tsíng-lí"

#: ui/main.qml:35
#, kde-format
msgid "Make Executable"
msgstr "Piau-tsò Ē-sái Tsip-hîng"

#: ui/main.qml:55
#, kde-format
msgid "The file '%1' must be executable to run at logout."
msgstr ""
"Tóng-àn '%1' su-iàu ē-sái tsip-hîng tsiah ē-sái tī ting-tshut ê sî-tsūn tsip-"
"hîng."

#: ui/main.qml:57
#, kde-format
msgid "The file '%1' must be executable to run at login."
msgstr ""
"Tóng-àn '%1' su-iàu ē-sái tsip-hîng tsiah ē-sái tī ting-ji̍p ê sî-tsūn tsip-"
"hîng."

#: ui/main.qml:68
#, kde-format
msgctxt "@action:button menu button; add new application etc"
msgid "Add New"
msgstr "Thiam Sin-ê"

#: ui/main.qml:69
#, kde-format
msgctxt "@title:menu accessible menu button"
msgid "Add new application or script"
msgstr "Thiam sin-ê ìng-iōng-tîng-sik á-sī tsí-līng-kó"

#: ui/main.qml:73
#, kde-format
msgctxt "@action:inmenu completes: add new application"
msgid "Application…"
msgstr "Ìng-iōng-tîng-sik…"

#: ui/main.qml:75
#, kde-format
msgctxt "@action:inmenu accessible"
msgid "Add application"
msgstr "Thiam ìng-iōng-tîng-sik"

#: ui/main.qml:79
#, kde-format
msgctxt "@action:inmenu completes: add new login script"
msgid "Login Script…"
msgstr "Ting-ji̍p Tsí-līng-kó…"

#: ui/main.qml:81
#, kde-format
msgctxt "@action:inmenu accessible"
msgid "Add login script"
msgstr "Thiam ting-ji̍p tsí-līng-kó"

#: ui/main.qml:85
#, kde-format
msgctxt "@action:inmenu completes: add new logout script"
msgid "Logout Script…"
msgstr "Ting-tshut Tsí-līng-kó…"

#: ui/main.qml:87
#, kde-format
msgctxt "@action:inmenu accessible"
msgid "Add logout script"
msgstr "Thiam ting-tshut tsí-līng-kó"

#: ui/main.qml:121
#, kde-format
msgid ""
"%1 has not been autostarted yet. Details will be available after the system "
"is restarted."
msgstr ""
"%1 á-buē hōo tsū-tōng-khí-tōng. Siông-sè tsu-sìn tī hē-thóng tîng-khí-tōng "
"liáu-āu tsiah ū-huat-tōo tsai-iánn."

#: ui/main.qml:144
#, kde-format
msgctxt ""
"@label Entry hasn't been autostarted because system hasn't been restarted"
msgid "Not autostarted yet"
msgstr "Á-buē tsū-tōng-khí-tōng"

#: ui/main.qml:153
#, kde-format
msgctxt "@action:button"
msgid "See properties"
msgstr "Hián-sī sio̍k-sìng"

#: ui/main.qml:164
#, kde-format
msgctxt "@action:button"
msgid "Remove entry"
msgstr "Î-tû hāng-bo̍k"

#: ui/main.qml:180
#, kde-format
msgid "Applications"
msgstr "Îng-ióng-tîng-sik"

#: ui/main.qml:183
#, kde-format
msgid "Login Scripts"
msgstr "Ting-ji̍p Tsí-līng-kó"

#: ui/main.qml:186
#, kde-format
msgid "Pre-startup Scripts"
msgstr "Khí-tōng Tsìn-tsîng ê Tsí-līng-kó"

#: ui/main.qml:189
#, kde-format
msgid "Logout Scripts"
msgstr "Ting-tshut Tsí-līng-kó"

#: ui/main.qml:198
#, kde-format
msgid "No user-specified autostart items"
msgstr "Bô iōng-tsiá tsí-tīng ê tsū-tōng-khí-tōng hāng-bo̍k"

#: ui/main.qml:199
#, kde-kuit-format
msgctxt "@info 'some' refers to autostart items"
msgid "Click the <interface>Add New</interface> button to add some"
msgstr "Tshi̍h <interface>Thiam Sin-ê</interface> lâi thiam"

#: ui/main.qml:214
#, kde-format
msgid "Choose Login Script"
msgstr "Suán Ting-ji̍p Tsí-līng-kó"

#: ui/main.qml:234
#, kde-format
msgid "Choose Logout Script"
msgstr "Suán Ting-tshut Tsí-līng-kó"

#: unit.cpp:26
#, kde-format
msgctxt "@label Entry is running right now"
msgid "Running"
msgstr "Leh tsip-hîng"

#: unit.cpp:27
#, kde-format
msgctxt "@label Entry is not running right now (exited without error)"
msgid "Not running"
msgstr "Bô leh tsip-hîng"

#: unit.cpp:28
#, kde-format
msgctxt "@label Entry is being started"
msgid "Starting"
msgstr "Leh khí-tōng"

#: unit.cpp:29
#, kde-format
msgctxt "@label Entry is being stopped"
msgid "Stopping"
msgstr "Leh thîng-tsí"

#: unit.cpp:30
#, kde-format
msgctxt "@label Entry has failed (exited with an error)"
msgid "Failed"
msgstr "Sit-pāi--ah"

#: unit.cpp:81
#, kde-format
msgid "Error occurred when receiving reply of GetAll call %1"
msgstr "Leh siu GetAll hoo-kiò %1 ê sî-tsūn huat-sing tshò-gōo"

#: unit.cpp:153
#, kde-format
msgid "Failed to open journal"
msgstr "Khui journal ê sî-tsūn sit-pāi--ah"
