msgid "Your emails"
msgstr "mail@kisaragi-hiu.com"

#: logout.cpp:260
#, kde-format
msgid "Logout canceled by '%1'"
msgstr "Ting-tshut hōo '%1' tshú-siau--ah"

#: logout.cpp:354
#, kde-format
msgctxt "@info:status"
msgid "Session is exiting"
msgstr "Kang-tsok-kai-tuānn leh lī-khui"

#: main.cpp:69 main.cpp:77
#, kde-format
msgid "No write access to '%1'."
msgstr "Bô khuân siá-ji̍p '%1'."

#: main.cpp:71 main.cpp:79
#, kde-format
msgid "No read access to '%1'."
msgstr "Bô khuân tho̍k-tshú '%1'."

#: main.cpp:84
#, kde-format
msgid ""
"The following installation problem was detected\n"
"while trying to start Plasma:"
msgstr ""
"Khí-tōng Plasma ê sî-tsūn tsing-tshik kàu\n"
"í-hā ê an-tsong būn-tê:"

#: main.cpp:87
#, kde-format
msgid ""
"\n"
"\n"
"Plasma is unable to start.\n"
msgstr ""
"\n"
"\n"
"Plasma bô-huat-tōo khí-tōng.\n"

#: main.cpp:111
#, kde-format
msgid ""
"The reliable Plasma session manager that talks the standard X11R6 \n"
"session management protocol (XSMP)."
msgstr ""
"Plasma tsiânn khó-khò ê kang-tsok-kai-tuānn kuán-lí-khì, ē kap piau-tsún \n"
"X11R6 kang-tsok-kai-tuānn kuán-lí hia̍p-tīng (XSMP) thong-sìn."

#: main.cpp:115
#, kde-format
msgid "Restores the saved user session if available"
msgstr "Ē-sái ê sî-tsūn hue-ho̍k tû-tsûn ê iōng-tsiá kang-tsok-kai-tuānn"

#: main.cpp:118
#, kde-format
msgid "Also allow remote connections"
msgstr "Mā ún-tsún uán-tuan liân-suànn"

#: server.cpp:764
#, kde-format
msgctxt "@label an unknown executable is using resources"
msgid "[unknown]"
msgstr "[m̄-tsai]"

#: server.cpp:787
#, kde-kuit-format
msgctxt "@label notification; %1 is a list of executables"
msgid ""
"Unable to manage some apps because the system's session management resources "
"are exhausted. Here are the top three consumers of session resources:\n"
"%1"
msgstr ""
"Bô-huat-tōo kuán-lí tsi̍t-kuá tîng-sik, in-uī hē-thóng ê kang-tsok-kai-tuānn "
"tsu-guân iōng liáu--ah. Tsia sī thâu sann ê leh lī-iōng kang-tsok-kai-tuānn "
"tsu-guân ê tîng-sik:\n"
"%1"

#: server.cpp:1042
#, kde-kuit-format
msgctxt "@label notification; %1 is an executable name"
msgid ""
"Unable to restore <application>%1</application> because it is broken and has "
"exhausted the system's session restoration resources. Please report this to "
"the app's developers."
msgstr ""
"Bô-huat-tōo hue-ho̍k <application>%1</application>, in-uī i phái-khì--ah, "
"suah kā hē-thóng ê kang-tsok-kai-tuānn hue-ho̍k tsu-guân iōng-liáu-liáu--ah. "
"Tshiánn kā tse būn-tê kap he tîng-sik ê khai-huat-tsiá huê-pò."
