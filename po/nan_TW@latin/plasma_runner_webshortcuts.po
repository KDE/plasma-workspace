#: webshortcutrunner.cpp:43 webshortcutrunner.cpp:135 webshortcutrunner.cpp:152
#, kde-format
msgid "Search %1 for %2"
msgstr "Tī %1 tshuē %2"

#: webshortcutrunner.cpp:67
#, kde-format
msgid "Opens \"%1\" in a web browser with the query :q:."
msgstr "Tī liû-lám-khì khui \"%1\" lâi tshuē :q:."

#: webshortcutrunner.cpp:72
#, kde-format
msgid "Search using the DuckDuckGo bang syntax"
msgstr "Iōng DuckDuckGo ê bang gí-huat tshuē"

#: webshortcutrunner.cpp:100
#, kde-format
msgid "Search in private window"
msgstr "Tī su-bi̍t sī-thang tshuē"

#: webshortcutrunner.cpp:100
#, kde-format
msgid "Search in incognito window"
msgstr "Tī bô-hûn sī-thang tshuē"
