#: kcm_soundtheme.cpp:156
#, kde-format
msgctxt "Name of the fallback \"freedesktop\" sound theme"
msgid "FreeDesktop"
msgstr "FreeDesktop"

#: kcm_soundtheme.cpp:157
#, kde-format
msgid "Fallback sound theme from freedesktop.org"
msgstr "Резервное звуковое оформление от freedesktop.org"

#: kcm_soundtheme.cpp:249
#, kde-format
msgctxt "@info:status"
msgid "Unable to create a temporary file."
msgstr "Не удалось создать временный файл."

#: kcm_soundtheme.cpp:259
#, kde-format
msgctxt "@info:status"
msgid "Unable to download the sound theme archive: %1"
msgstr "Не удалось загрузить архив звукового оформления: %1"

#: kcm_soundtheme.cpp:270
#, kde-format
msgctxt "@info:status"
msgid "The archive could not be opened."
msgstr "Не удалось открыть архив."

#: kcm_soundtheme.cpp:275
#, kde-format
msgctxt "@info:status"
msgid "Theme installed successfully."
msgid_plural "Themes installed successfully."
msgstr[0] "Оформления установлены успешно."
msgstr[1] "Оформления установлены успешно."
msgstr[2] "Оформления установлены успешно."
msgstr[3] "Оформление установлено успешно."

#: kcm_soundtheme.cpp:278
#, kde-format
msgctxt "@info:status"
msgid "The archive does not contain a valid sound theme."
msgstr "Архив не содержит допустимого звукового оформления."

#: ui/main.qml:35
#, kde-format
msgctxt "@action:button Install sound theme from file"
msgid "Install from File…"
msgstr "Установить из файла…"

#: ui/main.qml:42
#, kde-format
msgctxt "@option:check"
msgid "Enable notification sounds"
msgstr "Включить звуки уведомлений"

#: ui/main.qml:134
#, kde-format
msgctxt ""
"%2 is a theme name or a list of theme names that the current theme inherits "
"from"
msgid "Based on: %2"
msgid_plural "Based on: %2"
msgstr[0] "Основано на %2"
msgstr[1] "Основано на %2"
msgstr[2] "Основано на %2"
msgstr[3] "Основано на %2"

#: ui/main.qml:147
#, kde-format
msgctxt ""
"@label Precedes a list of buttons which can be clicked to preview the "
"theme's sounds. Keep it very short"
msgid "Preview:"
msgstr "Прослушать:"

#: ui/main.qml:166
#, kde-format
msgctxt "@info:tooltip"
msgid "Preview sound \"%1\""
msgstr "Прослушать звук «%1»"

#: ui/main.qml:188
#, kde-format
msgctxt "@info:tooltip"
msgid "Preview the demo sound for the theme \"%1\""
msgstr "Прослушать демонстрационный звук из оформления «%1»"

#: ui/main.qml:227
#, kde-format
msgctxt "%1 is a sound theme name. %2 is a sound name"
msgid "The %1 theme doesn't include the sound '%2'"
msgstr "Звуковое оформление «%1» не содержит звук «%2»"

#: ui/main.qml:232
#, kde-format
msgid "Failed to preview sound: %1"
msgstr "Не удалось воспроизвести звук: %1"

#: ui/main.qml:248
#, kde-format
msgctxt "@title:window"
msgid "Choose Sound Theme"
msgstr "Выбор звукового оформления"

#: ui/main.qml:250
#, kde-format
msgid "Theme Files (*.tar.gz *.tar.bz2 *.tar.xz *.tar.lz *.zip)"
msgstr "Файлы оформления (*.tar.gz *.tar.bz2 *.tar.xz *.tar.lz *.zip)"
