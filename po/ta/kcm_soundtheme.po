#: kcm_soundtheme.cpp:156
#, kde-format
msgctxt "Name of the fallback \"freedesktop\" sound theme"
msgid "FreeDesktop"
msgstr ""

#: kcm_soundtheme.cpp:157
#, kde-format
msgid "Fallback sound theme from freedesktop.org"
msgstr "freedesktop.org வழங்கும் பழுதுகாப்பு ஒலித்திட்டம்"

#: kcm_soundtheme.cpp:249
#, kde-format
msgctxt "@info:status"
msgid "Unable to create a temporary file."
msgstr "தற்காலிக கோப்பை உருவாக்க முடியவில்லை."

#: kcm_soundtheme.cpp:259
#, kde-format
msgctxt "@info:status"
msgid "Unable to download the sound theme archive: %1"
msgstr "ஒலித்திட்டத்திற்கான காப்பகக்கோப்பை பதிவிறக்க முடியவில்லை: %1"

#: kcm_soundtheme.cpp:270
#, kde-format
msgctxt "@info:status"
msgid "The archive could not be opened."
msgstr "காப்பகக்கோப்பைத் திறக்க முடியவில்லை."

#: kcm_soundtheme.cpp:275
#, kde-format
msgctxt "@info:status"
msgid "Theme installed successfully."
msgid_plural "Themes installed successfully."
msgstr[0] "ஒலித்திட்டம் வெற்றிகரமாக நிறுவப்பட்டது."
msgstr[1] "ஒலித்திட்டங்கள் வெற்றிகரமாக நிறுவப்பட்டன."

#: kcm_soundtheme.cpp:278
#, kde-format
msgctxt "@info:status"
msgid "The archive does not contain a valid sound theme."
msgstr "காப்பகக்கோப்பில் முறையான ஒலித்திட்டம் இல்லை."

#: ui/main.qml:35
#, kde-format
msgctxt "@action:button Install sound theme from file"
msgid "Install from File…"
msgstr "கோப்பிலிருந்து நிறுவு…"

#: ui/main.qml:42
#, kde-format
msgctxt "@option:check"
msgid "Enable notification sounds"
msgstr "அறிவிப்புகளுக்கான ஒலிகளை இயக்கு"

#: ui/main.qml:134
#, kde-format
msgctxt ""
"%2 is a theme name or a list of theme names that the current theme inherits "
"from"
msgid "Based on: %2"
msgid_plural "Based on: %2"
msgstr[0] "பின்வருவதைச் சார்ந்த‍து: %2"
msgstr[1] "பின்வருபவற்றைச் சார்ந்த‍து: %2"

#: ui/main.qml:147
#, kde-format
msgctxt ""
"@label Precedes a list of buttons which can be clicked to preview the "
"theme's sounds. Keep it very short"
msgid "Preview:"
msgstr "முன்னோட்டம்"

#: ui/main.qml:166
#, kde-format
msgctxt "@info:tooltip"
msgid "Preview sound \"%1\""
msgstr "\"%1\" எனும் ஒலியின் முன்னோட்டம்"

#: ui/main.qml:188
#, kde-format
msgctxt "@info:tooltip"
msgid "Preview the demo sound for the theme \"%1\""
msgstr "\"%1\" எனும் ஒலித்திட்டத்தின் முன்னோட்டங்காட்டும்"

#: ui/main.qml:227
#, kde-format
msgctxt "%1 is a sound theme name. %2 is a sound name"
msgid "The %1 theme doesn't include the sound '%2'"
msgstr "%1 எனும் ஒலித்திட்டத்தில் '%2' என்பதற்கான ஒலி இல்லை"

#: ui/main.qml:232
#, kde-format
msgid "Failed to preview sound: %1"
msgstr "ஒலியின் முன்னோட்டங்காட்டுவது தோல்வியடைந்தது: %1"

#: ui/main.qml:248
#, kde-format
msgctxt "@title:window"
msgid "Choose Sound Theme"
msgstr "ஒலித்திட்டத்தை தேர்ந்தெடுப்பது"

#: ui/main.qml:250
#, kde-format
msgid "Theme Files (*.tar.gz *.tar.bz2 *.tar.xz *.tar.lz *.zip)"
msgstr "ஒலித்திட்ட கோப்புகள் (*.tar.gz *.tar.bz2)"
