#: main.cpp:53 plasmawindowedcorona.cpp:104
#, kde-format
msgid "Plasma Windowed"
msgstr "சாளர பிளாஸ்மாய்டுகள்"

#: main.cpp:55
#, kde-format
msgid "Enable QML Javascript debugger"
msgstr "QML JavaScript பிழைநீக்கியை இயக்கு"

#: main.cpp:58 plasmawindowedcorona.cpp:106
#, kde-format
msgid ""
"Makes the plasmoid stay alive in the Notification Area, even when the window "
"is closed."
msgstr "சாளரத்தை மூடியபின்பும் பிளாஸ்மாய்டை கணினித் தட்டில் தக்கவைக்கும்"

#: main.cpp:60
#, kde-format
msgid "Force loading the given shell plugin"
msgstr "குறிப்பிட்டுள்ள செருகுநிரலை கட்டாயப்படுத்தி ஏற்று"

#: main.cpp:64 plasmawindowedcorona.cpp:107
#, kde-format
msgid "The applet to open."
msgstr "திறக்க வேண்டிய பிளாஸ்மாய்ட்"

#: main.cpp:65 plasmawindowedcorona.cpp:108
#, kde-format
msgid "Arguments to pass to the plasmoid."
msgstr "பிளாஸ்மாய்ட்க்கான தருமதிப்புகள்"

#: plasmawindowedview.cpp:118
#, kde-format
msgid "Close %1"
msgstr "%1 தனை மூடு"
