#: qml/main.qml:70
#, kde-format
msgctxt "Opens the system settings module"
msgid "Configure Virtual Keyboards..."
msgstr "Налаштувати віртуальні клавіатури…"

#: qml/main.qml:87
#, kde-format
msgid "Virtual Keyboard: unavailable"
msgstr "Віртуальна клавіатура: недоступна"

#: qml/main.qml:96
#, kde-format
msgid "Virtual Keyboard: disabled"
msgstr "Віртуальна клавіатура: вимкнено"

#: qml/main.qml:108
#, kde-format
msgid "Show Virtual Keyboard"
msgstr "Показати віртуальну клавіатуру"

#: qml/main.qml:119
#, kde-format
msgid "Virtual Keyboard: visible"
msgstr "Віртуальна клавіатура: видима"

#: qml/main.qml:128
#, kde-format
msgid "Virtual Keyboard: Show on non-mouse input"
msgstr "Віртуальна клавіатура: показувати при введенні поза мишею"

#: qml/main.qml:137
#, kde-format
msgid "Virtual Keyboard: Show with all input devices"
msgstr "Віртуальна клавіатура: показувати для усіх пристроїв введення"

#~ msgid "Virtual Keyboard: enabled"
#~ msgstr "Віртуальна клавіатура: увімкнено"
