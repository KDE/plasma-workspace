#: module.cpp:68
#, kde-format
msgctxt "@title"
msgid "Memory Shortage Avoided"
msgstr "Уникнено нестачі пам'яті"

#: module.cpp:71
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<command>%1</command> has been terminated by the Linux kernel because the "
"system is low on memory. Consider closing unused applications or browser "
"tabs."
msgstr ""
"<command>%1</command> було завершено ядром Linux через брак пам'яті в "
"системі. Спробуйте завершити роботу програм та вкладок браузера, якими не "
"користуєтеся."

#: module.cpp:77
#, kde-kuit-format
msgctxt "@info"
msgid ""
"The background service <command>%1</command> has been terminated by the "
"Linux kernel because the system is low on memory. Consider closing unused "
"applications or browser tabs."
msgstr ""
"Роботу фонової служби <command>%1</command> було припинено ядром Linux через "
"нестачу пам'яті у системі. Спробуйте завершити роботу програм та вкладок "
"браузера, якими не користуєтеся."

#: module.cpp:85
#, kde-format
msgctxt "@action"
msgid "Restart Application"
msgstr "Перезапустити програму"
