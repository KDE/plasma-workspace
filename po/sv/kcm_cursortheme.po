#. i18n: ectx: label, entry (cursorTheme), group (Mouse)
#: cursorthemesettings.kcfg:9
#, kde-format
msgid "Name of the current pointer theme"
msgstr "Namn på aktuellt pekartema"

#. i18n: ectx: label, entry (cursorSize), group (Mouse)
#: cursorthemesettings.kcfg:13
#, kde-format
msgid "Current pointer size"
msgstr "Aktuell pekarstorlek"

#: kcmcursortheme.cpp:373
#, kde-format
msgid "Unable to create a temporary file."
msgstr "Kan inte skapa en tillfällig fil."

#: kcmcursortheme.cpp:384
#, kde-format
msgid "Unable to download the icon theme archive: %1"
msgstr "Kan inte ladda ner arkivet för ikontemat: %1"

#: kcmcursortheme.cpp:398
#, kde-format
msgctxt "@info"
msgid "Unable to open the icon theme archive."
msgstr "Kan inte öppna ikontemaarkivet."

#: kcmcursortheme.cpp:418
#, kde-format
msgid "The file is not a valid icon theme archive."
msgstr "Filen är inte ett giltigt arkiv för ikonteman."

#: kcmcursortheme.cpp:425
#, kde-format
msgid "Failed to create 'icons' folder."
msgstr "Misslyckades skapa katalogen 'icons'."

#: kcmcursortheme.cpp:434
#, kde-format
msgid ""
"A theme named %1 already exists in your icon theme folder. Do you want "
"replace it with this one?"
msgstr ""
"Ett tema med namn %1 finns redan i din katalog för ikonteman. Vill du "
"ersätta det med det här temat?"

#: kcmcursortheme.cpp:438
#, kde-format
msgid "Overwrite Theme?"
msgstr "Skriv över tema?"

#: kcmcursortheme.cpp:462
#, kde-format
msgid "Theme installed successfully."
msgstr "Tema installerat med lyckat resultat."

#. i18n: ectx: label, entry (cursorTimeout), group (BusyCursorSettings)
#. i18n: ectx: label, entry (taskbarTimeout), group (TaskbarButtonSettings)
#: launchfeedbacksettings.kcfg:19 launchfeedbacksettings.kcfg:33
#, kde-format
msgid "Timeout in seconds"
msgstr "Tidsgräns i sekunder"

#: plasma-apply-cursortheme.cpp:38
#, kde-format
msgid ""
"This tool allows you to set the mouse pointer theme for the current Plasma "
"session, without accidentally setting it to one that is either not "
"available, or which is already set."
msgstr ""
"Verktyget låter dig ställa in muspekartemat för den aktuella Plasma-"
"sessionen, utan att av misstag ställa in det till ett som antingen inte är "
"tillgängligt eller som redan används."

#: plasma-apply-cursortheme.cpp:42
#, kde-format
msgid ""
"The name of the pointer theme you wish to set for your current Plasma "
"session (passing a full path will only use the last part of the path)"
msgstr ""
"Namnet på pekartemat som du vill använda för den aktuella Plasma-sessionen "
"(om en fullständig sökväg anges används bara den senare delen av sökvägen)"

#: plasma-apply-cursortheme.cpp:43
#, kde-format
msgid ""
"Show all the themes available on the system (and which is the current theme)"
msgstr ""
"Visa alla tillgängliga teman på system (och vilket som är det aktuella temat)"

#: plasma-apply-cursortheme.cpp:44
#, kde-format
msgid "Use a specific size, rather than the theme default size"
msgstr "Använd en specifik storlek istället för temats standardstorlek"

#: plasma-apply-cursortheme.cpp:65
#, kde-format
msgid ""
"The requested theme “%1” is already set as the theme for the current Plasma "
"session."
msgstr ""
"Begärt tema “%1” är redan använt som tema för den aktuella Plasma-sessionen."

#: plasma-apply-cursortheme.cpp:77
#, kde-format
msgid ""
"Successfully applied the mouse pointer theme %1 to your current Plasma "
"session"
msgstr ""
"Införde muspekartemat %1 med lyckat resultat för den aktuella Plasma-"
"sessionen"

#: plasma-apply-cursortheme.cpp:79
#, kde-format
msgid ""
"You have to restart the Plasma session for your newly applied mouse pointer "
"theme to display correctly."
msgstr ""
"Du måste starta om Plasma-sessionen för att det nytillagda muspekartemat ska "
"visas korrekt."

#: plasma-apply-cursortheme.cpp:89
#, kde-format
msgid ""
"Could not find theme “%1”. The theme should be one of the following options: "
"%2"
msgstr ""
"Kunde inte hitta temat “%1”. Temat ska vara ett av följande alternativ: %2"

#: plasma-apply-cursortheme.cpp:97
#, kde-format
msgid "You have the following mouse pointer themes on your system:"
msgstr "Du har följande muspekarteman på systemet:"

#: plasma-apply-cursortheme.cpp:102
#, kde-format
msgid "(Current theme for this Plasma session)"
msgstr "(Aktuellt tema för Plasma-sessionen)"

#: ui/Delegate.qml:48
#, kde-format
msgctxt "@info:tooltip"
msgid "Remove pointer theme"
msgstr "Ta bort pekartema"

#: ui/Delegate.qml:50
#, kde-format
