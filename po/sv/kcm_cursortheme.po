msgstr "Kan inte ta bort det aktiva pekartemat"

#: ui/Delegate.qml:52
#, kde-format
msgctxt "@info:tooltip"
msgid "Cannot delete system-installed pointer themes"
msgstr "Kan inte ta bort systeminstallerade pekarteman"

#: ui/Delegate.qml:60
#, kde-format
msgid "Don’t delete this pointer theme"
msgstr "Ta inte bort det här pekartemat"

