#, kde-format
msgid "Fallback sound theme from freedesktop.org"
msgstr "Rezervna zvočna tema iz freedesktop.org"

#: kcm_soundtheme.cpp:249
#, kde-format
msgctxt "@info:status"
msgid "Unable to create a temporary file."
msgstr "Začasne datoteke ni mogoče ustvariti."

