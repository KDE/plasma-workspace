msgstr[0] "Osnovan na: %2"
msgstr[1] "Osnovan na: %2"
msgstr[2] "Osnovan na: %2"
msgstr[3] "Osnovan na: %2"

#: ui/main.qml:147
#, kde-format
msgctxt ""
"@label Precedes a list of buttons which can be clicked to preview the "
"theme's sounds. Keep it very short"
