#: module.cpp:68
#, kde-format
msgctxt "@title"
msgid "Memory Shortage Avoided"
msgstr "Unngjekk å sleppa opp for minne"

#: module.cpp:71
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<command>%1</command> has been terminated by the Linux kernel because the "
"system is low on memory. Consider closing unused applications or browser "
"tabs."
msgstr ""
"<command>%1</command> har blitt tvangsavslutta av Linux-kjernen, då systemet "
"heldt på å sleppa opp for minne. Vurder å lukka ubrukte program eller "
"nettlesarfaner."

#: module.cpp:77
#, kde-kuit-format
msgctxt "@info"
msgid ""
"The background service <command>%1</command> has been terminated by the "
"Linux kernel because the system is low on memory. Consider closing unused "
"applications or browser tabs."
msgstr ""
"Bakgrunnstenesta <command>%1</command> har blitt tvangsavslutta av Linux-"
"kjernen, då systemet heldt på å sleppa opp for minne. Vurder å lukka ubrukte "
"program eller nettlesarfaner."

#: module.cpp:85
#, kde-format
msgctxt "@action"
msgid "Restart Application"
msgstr "Start programmet på nytt"
