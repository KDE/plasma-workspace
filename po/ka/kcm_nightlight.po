#: ui/DayNightView.qml:154
#, kde-format
msgid ""
"Color temperature begins changing to night time at %1 and is fully changed "
"by %2"
msgstr ""
"ფერის ტემპერატურა ღამის ფერებზე გადასვლას %1-ზე დაიწყებს და სრულად %2-ზე "
"გადავა"

#: ui/DayNightView.qml:157
#, kde-format
msgid ""
"Color temperature begins changing to day time at %1 and is fully changed by "
"%2"
msgstr ""
"ფერის ტემპერატურა დღის ფერებზე გადასვლას %1-ზე დაიწყებს და სრულად %2-ზე "
"გადავა"

#: ui/main.qml:39
#, kde-format
msgctxt "@info"
msgid "The blue light filter makes the colors on the screen warmer."
msgstr "ლურჯი სინათლის ფილტრი ეკრანის ფერებს უფრო თბილ ფერებზე გადართავს."

#: ui/main.qml:49
#, kde-format
msgctxt "@label:listbox Night Light modes"
msgid "Switching times:"
msgstr "გადართვის დრო:"

#: ui/main.qml:58
#, kde-format
msgctxt "@item:inlistbox switching times"
msgid "Always off"
msgstr "ყოველთვის გამორთული"

#: ui/main.qml:59
#, kde-format
msgctxt "@item:inlistbox switching times"
msgid "Always on"
msgstr "ყოველთვის ჩართული"

#: ui/main.qml:60
#, kde-format
msgctxt "@item:inlistbox switching times"
msgid "Sunrise and sunset"
msgstr "აისი და დაისი"

#: ui/main.qml:72
#, kde-format
msgctxt "@action:button Configure day-night cycle times"
msgid "Configure…"
msgstr "მორგება…"

#: ui/main.qml:115 ui/main.qml:166 ui/main.qml:230
#, kde-format
msgctxt "Color temperature in Kelvin"
msgid "%1 K"
msgstr "%1 კ"

#: ui/main.qml:123
#, kde-format
msgctxt "@label:slider"
msgid "Day light temperature:"
msgstr "დღის ფერების ტემპერატურა:"

#: ui/main.qml:173 ui/main.qml:237
#, kde-format
msgctxt "Night colour blue-ish; no blue light filter activated"
msgid "Cool (no filter)"
msgstr "გრილი (ფილტრის გარეშე)"

#: ui/main.qml:180 ui/main.qml:244
#, kde-format
msgctxt "Night colour red-ish"
msgid "Warm"
msgstr "თბილი"

#: ui/main.qml:187
#, kde-format
msgctxt "@label:slider"
msgid "Night light temperature:"
msgstr "ღამის ფერების ტემპერატურა:"
