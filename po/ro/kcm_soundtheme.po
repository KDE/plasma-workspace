#: kcm_soundtheme.cpp:156
#, kde-format
msgctxt "Name of the fallback \"freedesktop\" sound theme"
msgid "FreeDesktop"
msgstr "FreeDesktop"

#: kcm_soundtheme.cpp:157
#, kde-format
msgid "Fallback sound theme from freedesktop.org"
msgstr "Tematică sonoră de rezervă de la freedesktop.org"

#: kcm_soundtheme.cpp:249
#, kde-format
msgctxt "@info:status"
msgid "Unable to create a temporary file."
msgstr "Nu s-a putut crea un fișier temporar."

#: kcm_soundtheme.cpp:259
#, kde-format
msgctxt "@info:status"
msgid "Unable to download the sound theme archive: %1"
msgstr "Nu s-a putut descărca arhiva cu tematici de sunete: %1"

#: kcm_soundtheme.cpp:270
#, kde-format
msgctxt "@info:status"
msgid "The archive could not be opened."
msgstr "Arhiva nu a putut fi deschisă."

#: kcm_soundtheme.cpp:275
#, kde-format
msgctxt "@info:status"
msgid "Theme installed successfully."
msgid_plural "Themes installed successfully."
msgstr[0] "Tematica a fost instalată cu succes."
msgstr[1] "Tematicile au fost instalate cu succes."
msgstr[2] "Tematicile au fost instalate cu succes."

#: kcm_soundtheme.cpp:278
#, kde-format
msgctxt "@info:status"
msgid "The archive does not contain a valid sound theme."
msgstr "Arhiva nu conține o tematică de sunete validă."

#: ui/main.qml:35
#, kde-format
msgctxt "@action:button Install sound theme from file"
msgid "Install from File…"
msgstr "Instalează din fișier…"

#: ui/main.qml:42
#, kde-format
msgctxt "@option:check"
msgid "Enable notification sounds"
msgstr "Activează sunetele de notificare"

#: ui/main.qml:134
#, kde-format
msgctxt ""
"%2 is a theme name or a list of theme names that the current theme inherits "
"from"
msgid "Based on: %2"
msgid_plural "Based on: %2"
msgstr[0] "Bazată pe: %2"
msgstr[1] "Bazată pe: %2"
msgstr[2] "Bazată pe: %2"

#: ui/main.qml:147
#, kde-format
msgctxt ""
"@label Precedes a list of buttons which can be clicked to preview the "
"theme's sounds. Keep it very short"
msgid "Preview:"
msgstr "Ascultă:"

#: ui/main.qml:166
#, kde-format
msgctxt "@info:tooltip"
msgid "Preview sound \"%1\""
msgstr "Previzualizează sunetul „%1”"

#: ui/main.qml:188
#, kde-format
msgctxt "@info:tooltip"
msgid "Preview the demo sound for the theme \"%1\""
msgstr "Previzualizează sunetul demonstrativ pentru tematica „%1”"

#: ui/main.qml:227
#, kde-format
msgctxt "%1 is a sound theme name. %2 is a sound name"
msgid "The %1 theme doesn't include the sound '%2'"
msgstr "Tematica %1 nu include sunetul „%2”"

#: ui/main.qml:232
#, kde-format
msgid "Failed to preview sound: %1"
msgstr "Previzualizarea sunetului a eșuat: %1"

#: ui/main.qml:248
#, kde-format
msgctxt "@title:window"
msgid "Choose Sound Theme"
msgstr "Alegeți tematica de sunete"

#: ui/main.qml:250
#, kde-format
msgid "Theme Files (*.tar.gz *.tar.bz2 *.tar.xz *.tar.lz *.zip)"
