#: module.cpp:68
#, kde-format
msgctxt "@title"
msgid "Memory Shortage Avoided"
msgstr "Vyhnutí se nedostatku paměti"

#: module.cpp:71
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<command>%1</command> has been terminated by the Linux kernel because the "
"system is low on memory. Consider closing unused applications or browser "
"tabs."
msgstr ""
"<command>%1</command> byl ukončen jádrem Linuxu, protože systém má "
"nedostatek paměti. Zvažte zavření nepoužívaných aplikací nebo karet "
"prohlížeče."

#: module.cpp:77
#, kde-kuit-format
msgctxt "@info"
msgid ""
"The background service <command>%1</command> has been terminated by the "
"Linux kernel because the system is low on memory. Consider closing unused "
"applications or browser tabs."
msgstr ""
"Služba na pozadí <command>%1</command> byla ukončena jádrem systému Linux z "
"důvodu nedostatku paměti. Zvažte zavření nepoužívaných aplikací nebo karet "
"prohlížeče."

#: module.cpp:85
#, kde-format
msgctxt "@action"
msgid "Restart Application"
msgstr "Restartovat aplikaci"
