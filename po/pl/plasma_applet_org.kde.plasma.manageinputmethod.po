#: qml/main.qml:70
#, kde-format
msgctxt "Opens the system settings module"
msgid "Configure Virtual Keyboards..."
msgstr "Ustawienia klawiatur ekranowych…"

#: qml/main.qml:87
#, kde-format
msgid "Virtual Keyboard: unavailable"
msgstr "Klawiatura ekranowa: niedostępna"

#: qml/main.qml:96
#, kde-format
msgid "Virtual Keyboard: disabled"
msgstr "Klawiatura ekranowa: wyłączona"

#: qml/main.qml:108
#, kde-format
msgid "Show Virtual Keyboard"
msgstr "Pokaż klawiaturę ekranową"

#: qml/main.qml:119
#, kde-format
msgid "Virtual Keyboard: visible"
msgstr "Klawiatura ekranowa: widoczna"

#: qml/main.qml:128
#, kde-format
msgid "Virtual Keyboard: Show on non-mouse input"
msgstr "Klawiatura ekranowa: Pokaż przy obsłudze bez myszy"

#: qml/main.qml:137
#, kde-format
msgid "Virtual Keyboard: Show with all input devices"
msgstr "Klawiatura ekranowa: Pokaż przy obsłudze wszystkimi urządzeniami"

#~ msgid "Virtual Keyboard: enabled"
#~ msgstr "Klawiatura ekranowa: włączona"
