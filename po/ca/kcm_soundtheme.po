#: kcm_soundtheme.cpp:156
#, kde-format
msgctxt "Name of the fallback \"freedesktop\" sound theme"
msgid "FreeDesktop"
msgstr "FreeDesktop"

#: kcm_soundtheme.cpp:157
#, kde-format
msgid "Fallback sound theme from freedesktop.org"
msgstr "Tema de so alternatiu de reserva de «freedesktop.org»"

#: kcm_soundtheme.cpp:249
#, kde-format
msgctxt "@info:status"
msgid "Unable to create a temporary file."
msgstr "No s'ha pogut crear el fitxer temporal."

#: kcm_soundtheme.cpp:259
#, kde-format
msgctxt "@info:status"
msgid "Unable to download the sound theme archive: %1"
msgstr "No s'ha pogut baixar l'arxiu de tema de so: %1"

#: kcm_soundtheme.cpp:270
#, kde-format
msgctxt "@info:status"
msgid "The archive could not be opened."
msgstr "No s'ha pogut obrir l'arxiu."

#: kcm_soundtheme.cpp:275
#, kde-format
msgctxt "@info:status"
msgid "Theme installed successfully."
msgid_plural "Themes installed successfully."
msgstr[0] "El tema s'ha instal·lat correctament."
msgstr[1] "Els temes s'han instal·lat correctament."

#: kcm_soundtheme.cpp:278
#, kde-format
msgctxt "@info:status"
msgid "The archive does not contain a valid sound theme."
msgstr "L'arxiu no conté cap tema de so vàlid."

#: ui/main.qml:35
#, kde-format
msgctxt "@action:button Install sound theme from file"
msgid "Install from File…"
msgstr "Instal·la des d'un fitxer…"

#: ui/main.qml:42
#, kde-format
msgctxt "@option:check"
msgid "Enable notification sounds"
msgstr "Activa els sons de notificació"

#: ui/main.qml:134
#, kde-format
msgctxt ""
"%2 is a theme name or a list of theme names that the current theme inherits "
"from"
msgid "Based on: %2"
msgid_plural "Based on: %2"
msgstr[0] "Basat en: %2"
msgstr[1] "Basats en: %2"

#: ui/main.qml:147
#, kde-format
msgctxt ""
"@label Precedes a list of buttons which can be clicked to preview the "
"theme's sounds. Keep it very short"
msgid "Preview:"
msgstr "Prova:"

#: ui/main.qml:166
#, kde-format
msgctxt "@info:tooltip"
msgid "Preview sound \"%1\""
msgstr "Presentació preliminar del so «%1»"

#: ui/main.qml:188
#, kde-format
msgctxt "@info:tooltip"
msgid "Preview the demo sound for the theme \"%1\""
msgstr "Presentació preliminar del so de mostra per al tema «%1»"

#: ui/main.qml:227
#, kde-format
msgctxt "%1 is a sound theme name. %2 is a sound name"
msgid "The %1 theme doesn't include the sound '%2'"
msgstr "El tema %1 no inclou el so «%2»"

#: ui/main.qml:232
#, kde-format
msgid "Failed to preview sound: %1"
msgstr "La presentació preliminar del so ha fallat: %1"

#: ui/main.qml:248
#, kde-format
msgctxt "@title:window"
msgid "Choose Sound Theme"
msgstr "Escolliu un tema de so"

#: ui/main.qml:250
#, kde-format
msgid "Theme Files (*.tar.gz *.tar.bz2 *.tar.xz *.tar.lz *.zip)"
msgstr "Fitxers de temes (*.tar.gz *.tar.bz2 *.tar.xz *.tar.lz *.zip)"
