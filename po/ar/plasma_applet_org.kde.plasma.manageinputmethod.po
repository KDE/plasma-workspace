#: qml/main.qml:70
#, kde-format
msgctxt "Opens the system settings module"
msgid "Configure Virtual Keyboards..."
msgstr "اضبط لوحات المفاتيح الافتراضية..."

#: qml/main.qml:87
#, kde-format
msgid "Virtual Keyboard: unavailable"
msgstr "لوحة المفاتيح الافتراضيّة: غير متوفرة"

#: qml/main.qml:96
#, kde-format
msgid "Virtual Keyboard: disabled"
msgstr "لوحة المفاتيح الافتراضيّة: معطلة"

#: qml/main.qml:108
#, kde-format
msgid "Show Virtual Keyboard"
msgstr "أظهر لوحة المفاتيح الافتراضية"

#: qml/main.qml:119
#, kde-format
msgid "Virtual Keyboard: visible"
